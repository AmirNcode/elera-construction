---
import PageLayout from '~/layouts/PageLayout.astro';
import ProcessSteps from '~/components/sections/ProcessSteps.astro';
import SectionHeading from '~/components/ui/SectionHeading.astro';
import FaqAccordion from '~/components/ui/FaqAccordion.astro';
import Button from '~/components/ui/Button.astro';
import TrustStrip from '~/components/sections/TrustStrip.astro';
import JsonLd from '~/components/seo/JsonLd.astro';
import { buildFAQPage } from '~/lib/seo';

const processFaqs = [
  {
    question: "How quickly can you get started?",
    answer:
      "Once a contract is signed, most renovations start within 2–6 weeks depending on permit requirements, cabinetry lead times, and our current schedule. We'll give you a confirmed start date in writing as part of the contract.",
  },
  {
    question: "What if I want to make changes after work has started?",
    answer:
      "Scope changes are normal. We document them with a written change order: cost impact, schedule impact, and reason — signed by both parties before the work proceeds. No verbal 'while you're at it' work.",
  },
  {
    question: "How are payments structured?",
    answer:
      "Milestone-based draws tied to construction verifiables. Typical bathroom: 10% on signing, 40% on rough-in complete, 40% on tile complete, 10% on final walkthrough. Full home reno splits across more milestones. Payment schedule is in your contract.",
  },
  {
    question: "Do you provide a written warranty?",
    answer:
      "Yes. Two-year workmanship warranty in writing on everything we build, signed and dated as part of your closeout package. Manufacturer warranties on appliances, fixtures, and cabinetry pass through directly to you.",
  },
  {
    question: "Will the same crew be on my project the whole time?",
    answer:
      "You'll have one project lead — the same person — from start to finish. Specialty trades (plumbing, electrical, tile, HVAC) cycle through as needed at the right stages, all coordinated by the project lead.",
  },
];
---
<PageLayout
  title="Our Process"
  description="The seven-step renovation process Elera Construction uses on every GTA project, from free consultation to two-year workmanship warranty."
  canonicalPath="/process"
>
  <Fragment slot="json-ld">
    <JsonLd data={buildFAQPage(processFaqs)} />
  </Fragment>

  <section class="bg-cream pt-16 pb-12 md:pt-24 md:pb-16">
    <div class="container-x max-w-3xl">
      <p class="eyebrow">How we work</p>
      <h1 class="mt-4 text-4xl md:text-6xl font-extrabold leading-tight">Same process, every project.</h1>
      <p class="mt-6 text-lg text-muted">
        The most expensive part of a renovation isn't the materials — it's the chaos. Our process is designed to eliminate it. Here are the seven steps, in order, with what you can expect at each one.
      </p>
    </div>
  </section>

  <TrustStrip />

  <ProcessSteps />

  <section class="py-24 md:py-32 bg-paper">
    <div class="container-x grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-5">
        <SectionHeading
          eyebrow="WHAT SETS OUR PROCESS APART"
          heading="Developer-grade discipline."
        />
      </div>
      <div class="lg:col-span-7 space-y-4 text-ink leading-relaxed">
        <p>
          Most renovation projects derail not because of bad tradespeople, but because of unclear scope, ad-hoc change management, and verbal payment arrangements. Our founder learned the alternative from years on the new-construction side, where every project ran on documented scope, written change orders, and milestone-based draws tied to construction verifiables.
        </p>
        <p>
          Your renovation follows the same playbook. The drawings come first. The materials get ordered before the demo starts. The trades are sequenced so each one shows up the morning after the previous one finished. You get a weekly written update — and the same project lead's cell number for everything in between.
        </p>
        <p>
          It's not magic. It's just professional construction management, applied to renovations.
        </p>
      </div>
    </div>
  </section>

  <section class="py-24 md:py-32 bg-cream border-t border-hairline">
    <div class="container-x max-w-3xl">
      <SectionHeading
        eyebrow="PROCESS · FAQ"
        heading="Common questions about how we work."
        align="center"
        class="mb-12"
      />
      <FaqAccordion items={processFaqs} />
    </div>
  </section>

  <section class="py-24 bg-ink text-cream">
    <div class="container-x text-center">
      <p class="eyebrow text-midnight-soft">Ready to start?</p>
      <h2 class="mt-3 text-3xl md:text-5xl font-extrabold text-cream">Free consultation. Written quote in 5 days.</h2>
      <div class="mt-8 flex flex-wrap gap-3 justify-center">
        <Button href="/contact" variant="primary">Request a quote →</Button>
      </div>
    </div>
  </section>
</PageLayout>
