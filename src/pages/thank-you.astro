---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Logo from '~/components/brand/Logo.astro';
import Button from '~/components/ui/Button.astro';
import { site } from '~/lib/site';
---
<BaseLayout
  title="Thanks — we received your request"
  description="Your quote request has been received. We respond within 24 hours."
  noindex
>
  <main class="flex-1 grid place-items-center py-24">
    <div class="container-x max-w-2xl text-center">
      <Logo variant="stacked" size={64} class="text-midnight" />

      <p class="mt-12 eyebrow">Request received</p>
      <h1 class="mt-3 text-4xl md:text-5xl font-extrabold leading-tight">Thanks — we're on it.</h1>
      <p class="mt-6 text-lg text-muted">
        We've received your renovation enquiry and {site.founder} or someone from the Elera team will be in touch within 24 hours. Often sooner.
      </p>
      <p class="mt-4 text-muted">
        If your project is urgent, you can also call us directly at <a class="text-midnight font-semibold hover:underline" href={site.phoneHref}>{site.phone}</a>.
      </p>

      <div class="mt-12 grid sm:grid-cols-2 gap-4 text-left">
        <a href="/process" class="block bg-paper border border-hairline p-6 rounded-sm hover:border-midnight transition-colors">
          <p class="eyebrow">WHILE YOU WAIT</p>
          <h3 class="mt-2 text-lg font-extrabold text-ink">See how we work</h3>
          <p class="mt-2 text-sm text-muted">The 7-step process from consultation to closeout.</p>
          <span class="mt-3 inline-block text-sm font-semibold text-midnight">Our process →</span>
        </a>
        <a href="/projects" class="block bg-paper border border-hairline p-6 rounded-sm hover:border-midnight transition-colors">
          <p class="eyebrow">RECENT WORK</p>
          <h3 class="mt-2 text-lg font-extrabold text-ink">Browse our projects</h3>
          <p class="mt-2 text-sm text-muted">Bathroom, kitchen, flooring, full-home renovations.</p>
          <span class="mt-3 inline-block text-sm font-semibold text-midnight">See projects →</span>
        </a>
      </div>

      <div class="mt-12">
        <Button href="/" variant="ghost">Back to home</Button>
      </div>
    </div>
  </main>
</BaseLayout>
