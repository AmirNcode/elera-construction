---
import { getCollection, render } from 'astro:content';
import PageLayout from '~/layouts/PageLayout.astro';
import Breadcrumb from '~/components/ui/Breadcrumb.astro';
import Button from '~/components/ui/Button.astro';
import JsonLd from '~/components/seo/JsonLd.astro';
import { buildArticle, buildBreadcrumb } from '~/lib/seo';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((p) => !p.data.draft)
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const data = post.data;
const formattedDate = data.publishedAt.toLocaleDateString('en-CA', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: 'Blog', url: '/blog' },
  { name: data.title, url: `/blog/${post.id}` },
];
---
<PageLayout
  title={data.title}
  description={data.summary}
  canonicalPath={`/blog/${post.id}`}
>
  <Fragment slot="json-ld">
    <JsonLd
      data={buildArticle({
        title: data.title,
        summary: data.summary,
        slug: post.id,
        publishedAt: data.publishedAt,
        updatedAt: data.updatedAt,
      })}
    />
    <JsonLd data={buildBreadcrumb(breadcrumbItems)} />
  </Fragment>

  <section class="bg-cream pt-8 pb-12 md:pt-12 md:pb-16">
    <div class="container-x">
      <Breadcrumb items={breadcrumbItems} />
      <div class="mt-8 max-w-3xl">
        <p class="eyebrow">{formattedDate}</p>
        <h1 class="mt-4 text-4xl md:text-5xl font-extrabold leading-tight">{data.title}</h1>
        <p class="mt-6 text-lg text-muted">{data.summary}</p>
      </div>
    </div>
  </section>

  <section class="bg-paper py-12 md:py-16">
    <div class="container-x">
      <div class="aspect-[16/9] bg-hairline/60 grid place-items-center overflow-hidden rounded-sm max-w-4xl mx-auto">
        <img src={data.heroImage.src} alt={data.heroImage.alt} class="w-full h-full object-cover" />
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-paper">
    <div class="container-x">
      <article class="prose max-w-3xl mx-auto text-ink leading-relaxed">
        <Content />
      </article>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-cream border-t border-hairline">
    <div class="container-x text-center max-w-2xl">
      <p class="eyebrow">Ready when you are</p>
      <h2 class="mt-3 text-3xl md:text-4xl font-extrabold">Get a free quote.</h2>
      <p class="mt-4 text-muted">Free in-home consultation anywhere in the GTA. Line-item proposal within 5 business days.</p>
      <div class="mt-8 flex flex-wrap gap-3 justify-center">
        <Button href="/contact" variant="primary">Request a quote →</Button>
        <Button href="/blog" variant="secondary">Read more articles</Button>
      </div>
    </div>
  </section>
</PageLayout>
