---
import { getCollection } from 'astro:content';
import PageLayout from '~/layouts/PageLayout.astro';
import Hero from '~/components/sections/Hero.astro';
import TrustStrip from '~/components/sections/TrustStrip.astro';
import ServicesGrid from '~/components/sections/ServicesGrid.astro';
import ProcessSteps from '~/components/sections/ProcessSteps.astro';
import TestimonialCard from '~/components/sections/TestimonialCard.astro';
import ProjectCard from '~/components/sections/ProjectCard.astro';
import SectionHeading from '~/components/ui/SectionHeading.astro';
import FaqAccordion from '~/components/ui/FaqAccordion.astro';
import Button from '~/components/ui/Button.astro';
import { site } from '~/lib/site';

// Pull featured projects from the projects collection; fall back to the
// most-recent if none are flagged featured.
const allProjects = (await getCollection('projects')).sort(
  (a, b) => b.data.year - a.data.year,
);
const featured = allProjects.filter((p) => p.data.featured);
const featuredProjects = (featured.length > 0 ? featured : allProjects).slice(0, 3);

// Home-page FAQ teaser (4 most useful Qs). The full FAQ lives at /faq.
const homeFaqs = [
  {
    question: 'How long does a typical renovation take?',
    answer:
      'Bathrooms: 3–4 weeks. Kitchens: 5–8 weeks plus cabinetry lead time. Full-home renovations: 4–8 months. Add 2–4 weeks of design and material selection before construction starts.',
  },
  {
    question: 'How much will my renovation cost?',
    answer:
      'Every project is different — we give you a free in-home consultation followed by a line-item written quote within 5 business days. As rough benchmarks: bathrooms typically start around $18K; kitchens around $40K; full-home renovations from $150K. The Blog has detailed cost guides.',
  },
  {
    question: 'What\'s the supplier-pricing advantage?',
    answer:
      'Our founder spent 10+ years working with Toronto\'s largest residential developers and built supplier relationships in cabinetry, tile, stone, hardwood, and fixtures. Trade pricing through our accounts is typically 25–40% below retail showroom quotes for the same product.',
  },
  {
    question: 'Do you provide a warranty?',
    answer:
      '2-year workmanship warranty in writing on everything we build, plus pass-through of manufacturer warranties on appliances, fixtures, and cabinetry.',
  },
];
---
<PageLayout
  title={site.name}
  description={site.description}
>
  <Hero
    eyebrow="Greater Toronto Area"
    headline="Renovations built the way"
    headlineAccent="top developers"
    headlineTail="build."
    subhead="Bathrooms, kitchens, full-home renovations across the GTA — by a team with 10+ years building for Toronto's leading developers, and the supplier relationships to back it."
    primaryCta={{ label: 'Get a free quote', href: '/contact' }}
    secondaryCta={{ label: 'See our work', href: '/projects' }}
  />

  <TrustStrip />

  <ServicesGrid>
    <SectionHeading
      slot="heading"
      eyebrow="WHAT WE DO"
      heading="Renovations, done properly."
      subhead="From a single bathroom to a full-home gut. House, condo, or townhouse — same standard of work."
      align="center"
    />
  </ServicesGrid>

  <!-- "Why Elera" dark inset -->
  <section class="bg-ink text-cream py-24 md:py-32">
    <div class="container-x grid md:grid-cols-2 gap-12 md:gap-16 items-center">
      <div class="aspect-[4/3] bg-[#1a2530] grid place-items-center rounded-sm">
        <span class="text-sm text-cream/40">[Founder / project shot placeholder]</span>
      </div>
      <div>
        <p class="eyebrow text-midnight-soft">Why Elera</p>
        <h2 class="mt-4 text-3xl md:text-5xl font-extrabold leading-tight text-cream">
          Ten years building for <span class="text-midnight-soft italic font-light">the city's top developers.</span>
        </h2>
        <p class="mt-6 text-cream/75 leading-relaxed">
          Our founder, {site.founder}, spent over a decade on the build side of Toronto's largest residential projects — and brought every supplier relationship with him.
        </p>
        <p class="mt-4 text-cream/75 leading-relaxed">
          That means trade pricing on cabinetry, tile, stone, and flooring you simply can't get at retail — and a contractor who builds your kitchen the same way they build a $2M penthouse kitchen.
        </p>
        <div class="mt-8">
          <Button href="/about" variant="primary">Read our story →</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured projects -->
  <section class="py-24 md:py-32 bg-cream">
    <div class="container-x">
      <SectionHeading
        eyebrow="RECENT WORK"
        heading="See what we've built."
        subhead="A few recent projects across the GTA — bathrooms, kitchens, condos, and a full-home reno."
        align="center"
        class="mb-12"
      />
      <div class="grid md:grid-cols-3 gap-5">
        {featuredProjects.map((p) => (
          <ProjectCard
            href={`/projects/${p.id}`}
            title={p.data.title}
            location={p.data.location}
            year={p.data.year}
            services={p.data.services}
            heroSrc={p.data.heroImage.src}
            heroAlt={p.data.heroImage.alt}
          />
        ))}
      </div>
      <div class="mt-12 text-center">
        <Button href="/projects" variant="secondary">All projects →</Button>
      </div>
    </div>
  </section>

  <ProcessSteps compact stepLimit={4}>
    <SectionHeading
      slot="heading"
      eyebrow="OUR PROCESS"
      heading="How it works."
      subhead="Seven steps from free consultation to two-year warranty."
      align="center"
    />
  </ProcessSteps>
  <div class="bg-cream pb-24">
    <div class="container-x text-center">
      <Button href="/process" variant="secondary">Read the full process →</Button>
    </div>
  </div>

  <!-- Testimonial section -->
  <section class="py-24 bg-paper border-t border-hairline">
    <div class="container-x">
      <SectionHeading
        eyebrow="WHAT OUR CLIENTS SAY"
        heading="Trusted by GTA homeowners."
        align="center"
        class="mb-12"
      />
      <TestimonialCard />
    </div>
  </section>

  <!-- FAQ teaser -->
  <section class="py-24 md:py-32 bg-cream border-t border-hairline">
    <div class="container-x max-w-3xl">
      <SectionHeading
        eyebrow="QUESTIONS HOMEOWNERS ASK"
        heading="The quick answers."
        align="center"
        class="mb-12"
      />
      <FaqAccordion items={homeFaqs} />
      <div class="mt-12 text-center">
        <Button href="/faq" variant="secondary">All FAQs →</Button>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-24 md:py-32 bg-ink text-cream">
    <div class="container-x text-center max-w-2xl">
      <p class="eyebrow text-midnight-soft">Ready when you are</p>
      <h2 class="mt-3 text-3xl md:text-5xl font-extrabold text-cream">Free consultation. Honest quote. No pressure.</h2>
      <p class="mt-4 text-cream/70">Anywhere in the GTA. Line-item written proposal within 5 business days.</p>
      <div class="mt-8 flex flex-wrap gap-3 justify-center">
        <Button href="/contact" variant="primary">Get a free quote →</Button>
        <Button href={site.phoneHref} variant="secondary">Call {site.phone}</Button>
      </div>
    </div>
  </section>
</PageLayout>
