---
// Renders the visible breadcrumb trail. JSON-LD schema for the same items
// is emitted by the page itself (so it lands in BaseLayout's json-ld slot).
// See `buildBreadcrumb()` in `~/lib/seo`.

interface Item {
  name: string;
  url: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
const last = items.length - 1;
---
<nav aria-label="Breadcrumb" class="text-sm">
  <ol class="flex flex-wrap items-center gap-2 text-muted">
    {items.map((item, i) => (
      <li class="flex items-center gap-2">
        {i < last ? (
          <a href={item.url} class="hover:text-midnight">{item.name}</a>
        ) : (
          <span aria-current="page" class="text-ink font-semibold">{item.name}</span>
        )}
        {i < last && <span aria-hidden="true">/</span>}
      </li>
    ))}
  </ol>
</nav>
