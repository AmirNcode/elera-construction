---
import { getCollection } from 'astro:content';
import Card from '~/components/ui/Card.astro';

interface Props {
  /** Limit the number of services rendered. Default: all of them. */
  limit?: number;
}

const { limit } = Astro.props;

const services = (await getCollection('services'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
const visible = limit ? services.slice(0, limit) : services;
---
<section class="py-24 md:py-32">
  <div class="container-x">
    <slot name="heading" />
    <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {visible.map((svc) => (
        <Card href={`/services/${svc.id}`}>
          <h3 class="text-xl font-extrabold text-ink">{svc.data.title}</h3>
          <p class="mt-3 text-muted text-base leading-relaxed">{svc.data.summary}</p>
          <span class="mt-5 inline-block text-sm font-semibold text-midnight">Explore →</span>
        </Card>
      ))}
    </div>
  </div>
</section>
