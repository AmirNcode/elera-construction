---
import Card from '~/components/ui/Card.astro';

interface Props {
  href: string;
  title: string;
  summary: string;
  publishedAt: Date;
  heroSrc: string;
  heroAlt: string;
}

const { href, title, summary, publishedAt, heroSrc, heroAlt } = Astro.props;
const date = publishedAt.toLocaleDateString('en-CA', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<Card href={href} class="p-0 overflow-hidden">
  <div class="aspect-[16/9] bg-hairline/60 grid place-items-center overflow-hidden">
    <img src={heroSrc} alt={heroAlt} loading="lazy" class="w-full h-full object-cover" />
  </div>
  <div class="p-6">
    <p class="text-xs eyebrow">{date}</p>
    <h3 class="mt-2 text-xl font-extrabold text-ink leading-snug">{title}</h3>
    <p class="mt-3 text-muted text-sm leading-relaxed line-clamp-3">{summary}</p>
    <span class="mt-4 inline-block text-sm font-semibold text-midnight">Read more →</span>
  </div>
</Card>
