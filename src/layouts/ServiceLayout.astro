---
import PageLayout from '~/layouts/PageLayout.astro';
import Breadcrumb from '~/components/ui/Breadcrumb.astro';
import TrustStrip from '~/components/sections/TrustStrip.astro';
import FaqAccordion from '~/components/ui/FaqAccordion.astro';
import Button from '~/components/ui/Button.astro';
import SectionHeading from '~/components/ui/SectionHeading.astro';
import JsonLd from '~/components/seo/JsonLd.astro';
import { buildService, buildFAQPage, buildBreadcrumb } from '~/lib/seo';

interface Props {
  slug: string;
  title: string;
  summary: string;
  seoKeyword: string;
  serviceType: string;
  heroImage: { src: string; alt: string };
  whatsIncluded: string[];
  processNote?: string;
  faqs: { question: string; answer: string }[];
}

const {
  slug,
  title,
  summary,
  seoKeyword,
  serviceType,
  heroImage,
  whatsIncluded,
  processNote,
  faqs,
} = Astro.props;

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: 'Services', url: '/services' },
  { name: title, url: `/services/${slug}` },
];
---
<PageLayout
  title={`${title} in the GTA`}
  description={summary}
  canonicalPath={`/services/${slug}`}
>
  <Fragment slot="json-ld">
    <JsonLd
      data={buildService({
        name: title,
        slug,
        description: summary,
        serviceType: seoKeyword,
      })}
    />
    <JsonLd data={buildFAQPage(faqs)} />
    <JsonLd data={buildBreadcrumb(breadcrumbItems)} />
  </Fragment>

  <section class="bg-cream pt-8 pb-16 md:pt-12 md:pb-24">
    <div class="container-x">
      <Breadcrumb items={breadcrumbItems} />
      <div class="mt-8 grid md:grid-cols-2 gap-12 md:gap-16 items-center">
        <div>
          <p class="eyebrow">Greater Toronto Area</p>
          <h1 class="mt-4 text-4xl md:text-6xl font-extrabold leading-tight">{title}</h1>
          <p class="mt-6 text-lg text-muted max-w-prose">{summary}</p>
          <div class="mt-8 flex flex-wrap gap-3">
            <Button href="/contact" variant="primary">Get a quote →</Button>
            <Button href="/projects" variant="secondary">See our work</Button>
          </div>
        </div>
        <div class="aspect-[4/5] bg-hairline/60 grid place-items-center overflow-hidden rounded-sm">
          <img
            src={heroImage.src}
            alt={heroImage.alt}
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <TrustStrip />

  <section class="py-24 md:py-32 bg-paper">
    <div class="container-x grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-5">
        <SectionHeading
          eyebrow="WHAT'S INCLUDED"
          heading="Everything in scope."
        />
        {processNote && <p class="mt-6 text-muted leading-relaxed">{processNote}</p>}
      </div>
      <ul class="lg:col-span-7 grid gap-3">
        {whatsIncluded.map((item) => (
          <li class="flex gap-3 items-start">
            <span aria-hidden="true" class="mt-1 inline-grid place-items-center w-5 h-5 rounded-full border border-midnight text-midnight text-xs shrink-0">✓</span>
            <span class="text-ink leading-relaxed">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="py-24 md:py-32 bg-cream border-y border-hairline">
    <div class="container-x">
      <article class="prose max-w-3xl mx-auto text-ink">
        <slot />
      </article>
    </div>
  </section>

  <section class="py-24 md:py-32 bg-paper">
    <div class="container-x max-w-3xl">
      <SectionHeading
        eyebrow={`${title.toUpperCase()} · FAQ`}
        heading="Common questions, honest answers."
        align="center"
        class="mb-12"
      />
      <FaqAccordion items={faqs} />
    </div>
  </section>

  <section class="py-24 bg-ink text-cream">
    <div class="container-x text-center">
      <p class="eyebrow text-midnight-soft">Ready when you are</p>
      <h2 class="mt-3 text-3xl md:text-5xl font-extrabold text-cream">Get a written {title.toLowerCase()} quote.</h2>
      <p class="mt-4 text-cream/70 max-w-prose mx-auto">Free in-home consultation anywhere in the GTA. Line-item proposal within 5 business days. No sales pressure.</p>
      <div class="mt-8 flex flex-wrap gap-3 justify-center">
        <Button href="/contact" variant="primary">Request a quote →</Button>
      </div>
    </div>
  </section>
</PageLayout>
